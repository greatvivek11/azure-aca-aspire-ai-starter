{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "setup: ensure local AI env defaults",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/ensure-aspire-env.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-File", "${workspaceFolder}\\.vscode\\ensure-aspire-env.ps1"
				]
			}
		},
		{
			"label": "setup: ensure native llama.cpp",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/ensure-local-llm.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-File", "${workspaceFolder}\\.vscode\\ensure-local-llm.ps1"
				]
			}
		},
		{
			"label": "validate: native llama.cpp ready",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/ensure-local-llm-ready.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-File", "${workspaceFolder}\\.vscode\\ensure-local-llm-ready.ps1"
				]
			}
		},
		{
			"label": "tools: ensure Docker engine",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/ensure-docker.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-File", "${workspaceFolder}\\.vscode\\ensure-docker.ps1"
				]
			}
		},
		{
			"label": "tools: install Dapr CLI",
			"type": "shell",
			"command": "bash",
			"args": [
				"-c",
				"command -v dapr >/dev/null && echo \"[info] Dapr CLI already installed\" || (echo \"Installing Dapr CLI...\" && curl -fsSL https://raw.githubusercontent.com/dapr/cli/master/install/install.sh | /bin/bash)"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-File", "${workspaceFolder}\\.vscode\\install-dapr.ps1"
				]
			}
		},
		{
			"label": "setup: install all extensions",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/install-extensions.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-File", "${workspaceFolder}\\.vscode\\install-extensions.ps1"
				]
			}
		},
		{
			"label": "setup: ensure SQL Server connection profile",
			"type": "shell",
			"command": "echo",
			"args": [
				"Ensuring SQL connection profile for ms-mssql extension..."
			],
			"dependsOn": [
				"setup: install all extensions",
				"tools: ensure Docker engine"
			],
			"dependsOrder": "sequence",
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": [],
			"linux": {
				"command": "bash",
				"args": [
					".vscode/ensure-sql-connection-profile.sh"
				]
			},
			"osx": {
				"command": "bash",
				"args": [
					".vscode/ensure-sql-connection-profile.sh"
				]
			},
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-File", "${workspaceFolder}\\.vscode\\ensure-sql-connection-profile.ps1"
				]
			}
		},
		{
			"label": "tools: install Azure CLI",
			"type": "shell",
			"command": "bash",
			"args": [
				"-c",
				"command -v az >/dev/null && echo \"[info] Azure CLI already installed\" || (echo \"Installing Azure CLI via Homebrew...\" && brew install azure-cli)"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": [],
			"linux": {
				"args": [
					"-c",
					"command -v az >/dev/null && echo \"[info] Azure CLI already installed\" || (echo \"Installing Azure CLI...\" && curl -sL https://aka.ms/InstallAzureCLIDeb | bash) || echo \"[info] Azure CLI install skipped\""
				]
			},
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-NoProfile",
					"-Command",
					"if (Get-Command az -ErrorAction SilentlyContinue) { Write-Host '[info] Azure CLI already installed' } else { Write-Host '[info] Azure CLI install would require manual intervention or MSI download' }"
				]
			}
		},
		{
			"label": "tools: install Azure Developer CLI (azd)",
			"type": "shell",
			"command": "bash",
			"args": [
				"-c",
				"command -v azd >/dev/null && echo \"[info] azd already installed\" || (echo \"Installing Azure Developer CLI...\" && curl -fsSL https://aka.ms/install-azd.sh | bash)"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-NoProfile",
					"-Command",
					"if (Get-Command azd -ErrorAction SilentlyContinue) { Write-Host '[info] azd already installed' } else { Write-Host '[info] azd install would require manual intervention or installer download' }"
				]
			}
		},
		{
			"label": "setup: install all tools",
			"type": "shell",
			"command": "echo",
			"args": [
				"Setting up Dapr, Azure CLI, azd, and local LLM (devcontainer parity)..."
			],
			"dependsOn": [
				"setup: ensure local AI env defaults",
				"tools: ensure Docker engine",
				"setup: ensure native llama.cpp",
				"validate: native llama.cpp ready",
				"tools: install Dapr CLI",
				"tools: install Azure CLI",
				"tools: install Azure Developer CLI (azd)"
			],
			"dependsOrder": "sequence",
			"presentation": {
				"reveal": "silent"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "npm: install frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"ci"
			],
			"options": {
				"cwd": "${workspaceFolder}/src/frontend"
			},
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "dotnet: restore backend",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"restore",
				"${workspaceFolder}/src/backend/Backend.csproj"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "dotnet: restore worker",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"restore",
				"${workspaceFolder}/src/worker/Worker.csproj"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "setup: install all dependencies",
			"type": "shell",
			"command": "echo",
			"args": [
				"Installing frontend and backend dependencies..."
			],
			"dependsOn": [
				"npm: install frontend",
				"dotnet: restore backend",
				"dotnet: restore worker"
			],
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": []
		},
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/azure-aca-aspire-ai-starter.sln",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile",
			"dependsOn": [
				"setup: install all tools",
				"setup: install all dependencies"
			]
		},
		{
			"label": "publish",
			"command": "dotnet",
			"type": "process",
			"args": [
				"publish",
				"${workspaceFolder}/azure-aca-aspire-ai-starter.sln",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "watch",
			"command": "dotnet",
			"type": "process",
			"args": [
				"watch",
				"run",
				"--project",
				"${workspaceFolder}/src/aspire/aspire.csproj"
			],
			"isBackground": true,
			"problemMatcher": "$msCompile"
		},
		{
			"label": "validate: extensions in sync",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/validate-extensions-sync.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": [],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy", "Bypass",
					"-NoProfile",
					"-Command",
					"Write-Host '[info] Extension sync validation skipped on Windows'"
				]
			}
		}
	]
}
