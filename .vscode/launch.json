{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Aspire AppHost",
			"type": "coreclr",
			"request": "launch",
			"preLaunchTask": "build",
			"program": "${workspaceFolder}/src/aspire/bin/Debug/net10.0/aspire.dll",
			"args": [],
			"cwd": "${workspaceFolder}/src/aspire",
			"stopAtEntry": false,
			"serverReadyAction": {
				"action": "openExternally",
				"pattern": "\\bNow listening on:\\s+(https?://\\S+)"
			},
			"env": {
				"ASPNETCORE_ENVIRONMENT": "Development"
			}
		}
	],
	"compounds": [
		{
			"name": "Aspire: Launch",
			"configurations": ["Launch Aspire AppHost"]
		}
	]
}
