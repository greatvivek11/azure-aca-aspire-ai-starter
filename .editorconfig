# EditorConfig helps developers define and maintain consistent coding styles between different editors and IDEs
# More information: https://editorconfig.org/

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Code files settings
[*.{cs,csx,vb,vbx,js,jsx,ts,tsx,html,css,json,xml,md,sql,yml,yaml}]
indent_style = space
indent_size = 4

# C# files specific settings
[*.cs]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 4
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# JavaScript/TypeScript files specific settings
[*.{js,jsx,ts,tsx}]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 2
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# HTML files specific settings
[*.html]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 2
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# CSS files specific settings
[*.css]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 2
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# JSON files specific settings
[*.json]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 2
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# Markdown files specific settings
[*.md]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 2
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Do not remove trailing whitespace in Markdown as it can be significant
trim_trailing_whitespace = false

# YAML files specific settings
[*.{yml,yaml}]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 2
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# SQL files specific settings
[*.sql]
# Use UTF-8 encoding
charset = utf-8
