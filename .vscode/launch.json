{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Aspire AppHost",
			"type": "dotnet",
			"request": "launch",
			"preLaunchTask": "build",
			"projectPath": "${workspaceFolder}/src/aspire/aspire.csproj",
			"cwd": "${workspaceFolder}/src/aspire",
			"serverReadyAction": {
				"action": "openExternally",
				"pattern": "\\bNow listening on:\\s+(https?://\\S+)"
			},
			"env": {
				"ASPNETCORE_ENVIRONMENT": "Development",
				"ASPIRE_FRONTEND_MODE": "vite-dev"
			},
			"justMyCode": true,
			"logging": {
				"moduleLoad": false,
				"programOutput": true
			}
		}
	],
	"compounds": [
		{
			"name": "Aspire: Launch",
			"configurations": [
				"Launch Aspire AppHost"
			]
		}
	]
}
