{
	"name": ".NET Aspire Development Environment",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/app",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"enableNonRootDocker": true,
			"moby": true
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/dapr/cli/dapr-cli:0": {},
		"ghcr.io/devcontainers-extra/features/typescript:2": {}
	},
	"hostRequirements": {
		"cpus": 8,
		"memory": "11gb",
		"storage": "64gb"
	},
	"onCreateCommand": "n=1; until dotnet new install Aspire.ProjectTemplates --force; do [ $n -ge 3 ] && { echo '[warn] Aspire templates not installed after retries; continuing.'; break; }; echo \"[warn] template install attempt $n failed; retrying in 5s...\"; n=$((n+1)); sleep 5; done",
	"postCreateCommand": "bash .devcontainer/install-dev-tools.sh && export SSL_CERT_DIR=\"$HOME/.aspnet/dev-certs/trust:/usr/lib/ssl/certs\" && dotnet dev-certs https --trust",
	"postStartCommand": "export SSL_CERT_DIR=\"$HOME/.aspnet/dev-certs/trust:/usr/lib/ssl/certs\" && dotnet dev-certs https --trust",
	"customizations": {
		"vscode": {
			"settings": {
				"mssql.connections": [
					{
						"server": "localhost,1433",
						"database": "",
						"authenticationType": "SqlLogin",
						"user": "sa",
						"password": "P@ssw0rd",
						"emptyPasswordInput": false,
						"savePassword": false,
						"profileName": "mssql-container"
					}
				]
			},
			"extensions": [
				"ms-dotnettools.csdevkit",
				"ms-dotnettools.csharp",
				"ms-dotnettools.vscode-dotnet-runtime",
				"ms-mssql.mssql",
				"ms-azuretools.vscode-docker",
				"ms-azuretools.vscode-bicep",
				"ms-azuretools.vscode-azureresourcegroups",
				"github.vscode-github-actions",
				"dbaeumer.vscode-eslint",
				"biomejs.biome",
				"github.copilot",
				"github.copilot-chat"
			]
		}
	},
	"forwardPorts": [
		1433,
		15237,
		17251,
		19047,
		20059,
		21070,
		22055
	],
	"portsAttributes": {
		"17251": {
			"label": "Aspire Dashboard (HTTPS)"
		},
		"22055": {
			"label": "Aspire Resource Service (HTTPS)"
		},
		"21070": {
			"label": "Aspire OTLP gRPC (HTTPS)"
		},
		"15237": {
			"label": "Aspire Dashboard (HTTP)"
		},
		"20059": {
			"label": "Aspire Resource Service (HTTP)"
		},
		"19047": {
			"label": "Aspire OTLP gRPC (HTTP)"
		},
		"8443": {
			"label": "Frontend"
		},
		"1433": {
			"label": "SQL Server"
		}
	}
}
