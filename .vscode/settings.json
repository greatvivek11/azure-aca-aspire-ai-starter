{
	// Allow tasks with "runOn": "folderOpen" to execute automatically on workspace load.
	// Without this, VS Code silently skips auto-tasks even in a trusted workspace.
	"task.allowAutomaticTasks": "on",
	// Keep line endings and basic whitespace behavior consistent across host OS and devcontainers.
	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true
}
