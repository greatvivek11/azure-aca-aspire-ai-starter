indent_style = space
indent_size = 4
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
insert_final_newline = true
# Remove trailing whitespace
trim_trailing_whitespace = true

# Configuration files specific settings
[*.config]
# Use UTF-8 encoding
charset = utf-8
# Use spaces for indentation
indent_style = space
indent_size = 4
# New line characters should be lf (Unix style)
end_of_line = lf
# Ensure files end with a new line
