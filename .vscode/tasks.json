{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"type": "docker-build",
			"label": "docker-build: debug",
			"dependsOn": [
				"build"
			],
			"dockerBuild": {
				"tag": "acaaspireaistarter:dev",
				"target": "base",
				"dockerfile": "${workspaceFolder}/src/aspire/Dockerfile",
				"context": "${workspaceFolder}",
				"pull": true
			},
			"netCore": {
				"appProject": "${workspaceFolder}/src/aspire/aspire.csproj"
			}
		},
		{
			"type": "docker-build",
			"label": "docker-build: release",
			"dependsOn": [
				"build"
			],
			"dockerBuild": {
				"tag": "acaaspireaistarter:latest",
				"dockerfile": "${workspaceFolder}/src/aspire/Dockerfile",
				"context": "${workspaceFolder}",
				"platform": {
					"os": "linux",
					"architecture": "amd64"
				},
				"pull": true
			},
			"netCore": {
				"appProject": "${workspaceFolder}/src/aspire/aspire.csproj"
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: debug",
			"dependsOn": [
				"docker-build: debug"
			],
			"dockerRun": {},
			"netCore": {
				"appProject": "${workspaceFolder}/src/aspire/aspire.csproj",
				"enableDebugging": true
			}
		},
		{
			"type": "docker-run",
			"label": "docker-run: release",
			"dependsOn": [
				"docker-build: release"
			],
			"dockerRun": {},
			"netCore": {
				"appProject": "${workspaceFolder}/src/aspire/aspire.csproj"
			}
		},
		{
			"label": "setup-dev-tools",
			"type": "shell",
			"command": "bash",
			"args": [
				"${workspaceFolder}/scripts/setup-dev-tools.sh"
			],
			"problemMatcher": []
		},
		{
			"label": "frontend-lint",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"options": {
				"cwd": "${workspaceFolder}/src/frontend"
			},
			"problemMatcher": []
		},
		{
			"label": "backend-tests",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"${workspaceFolder}/src/Backend.Tests/Backend.Tests.csproj"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "noop",
			"type": "shell",
			"command": "true"
		},
		{
			"label": "publish",
			"command": "dotnet",
			"type": "process",
			"args": [
				"publish",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "watch",
			"command": "dotnet",
			"type": "process",
			"args": [
				"watch",
				"run"
			],
			"problemMatcher": "$msCompile"
		}
	]
}
