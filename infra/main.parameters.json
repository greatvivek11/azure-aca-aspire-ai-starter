{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "sqlAdminLogin": {
      "value": "${AZURE_SQL_ADMIN_LOGIN}"
    },
    "sqlAdminPassword": {
      "value": "${AZURE_SQL_ADMIN_PASSWORD}"
    },
    "tags": {
      "value": {
        "project": "copilot-sk-azure",
        "managedBy": "azd"
      }
    }
  }
}
