{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "setup: install all extensions",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/install-extensions.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "tools: install Azure CLI",
			"type": "shell",
			"command": "bash",
			"args": [
				"-c",
				"command -v az >/dev/null && echo \"[info] Azure CLI already installed\" || (echo \"Installing Azure CLI via Homebrew...\" && brew install azure-cli)"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": [],
			"linux": {
				"args": [
					"-c",
					"command -v az >/dev/null || (echo 'Installing Azure CLI...' && curl -sL https://aka.ms/InstallAzureCLIDeb | bash) || echo '[info] Azure CLI install skipped'"
				]
			}
		},
		{
			"label": "tools: install Azure Developer CLI (azd)",
			"type": "shell",
			"command": "bash",
			"args": [
				"-c",
				"command -v azd >/dev/null && echo \"[info] azd already installed\" || (echo \"Installing Azure Developer CLI...\" && curl -fsSL https://aka.ms/install-azd.sh | bash)"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "setup: install all tools",
			"type": "shell",
			"command": "echo",
			"args": [
				"Setting up Azure CLI and azd (devcontainer parity)..."
			],
			"dependsOn": [
				"tools: install Azure CLI",
				"tools: install Azure Developer CLI (azd)"
			],
			"presentation": {
				"reveal": "silent"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "npm: install frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"ci"
			],
			"options": {
				"cwd": "${workspaceFolder}/src/frontend"
			},
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "dotnet: restore backend",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"restore",
				"${workspaceFolder}/src/backend/Backend.csproj"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "dotnet: restore worker",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"restore",
				"${workspaceFolder}/src/worker/Worker.csproj"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		},
		{
			"label": "setup: install all dependencies",
			"type": "shell",
			"command": "echo",
			"args": [
				"Installing frontend and backend dependencies..."
			],
			"dependsOn": [
				"npm: install frontend",
				"dotnet: restore backend",
				"dotnet: restore worker"
			],
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": []
		},
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/azure-aca-aspire-ai-starter.sln",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile",
			"dependsOn": "setup: install all dependencies"
		},
		{
			"label": "publish",
			"command": "dotnet",
			"type": "process",
			"args": [
				"publish",
				"${workspaceFolder}/azure-aca-aspire-ai-starter.sln",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary;ForceNoAlign"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "watch",
			"command": "dotnet",
			"type": "process",
			"args": [
				"watch",
				"run",
				"--project",
				"${workspaceFolder}/src/aspire/aspire.csproj"
			],
			"isBackground": true,
			"problemMatcher": "$msCompile"
		},
		{
			"label": "validate: extensions in sync",
			"type": "shell",
			"command": "bash",
			"args": [
				".vscode/validate-extensions-sync.sh"
			],
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": []
		}
	]
}