# Copy this file to .env and fill in values for your environment.

# ----------------------------------------
# Frontend runtime mode
# ----------------------------------------
# container: production-like containerized frontend
# vite-dev: local Vite HMR mode (recommended for frontend iteration)
ASPIRE_FRONTEND_MODE=vite-dev

# ----------------------------------------
# AI runtime mode
# ----------------------------------------
# local: Ollama + Qdrant (local Docker-first)
# azure: Azure AI Foundry/OpenAI + Azure AI Search
AI_MODE=local

# ----------------------------------------
# Local AI mode defaults (used when AI_MODE=local)
# ----------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=gemma3:4b-it-qat
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=768
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# ----------------------------------------
# Azure mode settings (used when AI_MODE=azure)
# ----------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_MODEL_ID=gpt-5-mini
AZURE_OPENAI_ENDPOINT=https://your-foundry-resource.openai.azure.com/
# Optional auth mode:
# - api-key: use AZURE_OPENAI_API_KEY
# - managed-identity: try MI first, fallback to API key when present
AZURE_OPENAI_AUTH_MODE=api-key

# ----------------------------------------
# Storage for upload + ingestion
# For local mode, these defaults target local Azurite in Docker.
# ----------------------------------------
AZURE_OPENAI_EMBEDDING_MODEL_ID=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER_NAME=documents
AZURE_STORAGE_PUBLIC_BLOB_ENDPOINT=http://localhost:10000/devstoreaccount1
# Used by Azure signed-URL browser uploads; local mode uploads are backend-proxied.
BLOB_CORS_ALLOWED_ORIGINS_JSON=["http://localhost:3000","https://localhost:3000","http://127.0.0.1:3000","https://127.0.0.1:3000"]
# - api-key: use AZURE_STORAGE_CONNECTION_STRING for SAS and blob reads
# - managed-identity: try MI first, fallback to connection string when present
AZURE_STORAGE_AUTH_MODE=api-key
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=documents-index

# Optional: when not using managed identity for search reads
AZURE_SEARCH_API_KEY=

# Optional: backend search auth mode (default is api-key)
# - api-key: use AZURE_SEARCH_API_KEY (recommended default)
# - managed-identity: use ACA managed identity token first, API key fallback
AZURE_SEARCH_AUTH_MODE=api-key

# Optional: signed upload URL validity window (minutes, 5-120, default 15)
# UPLOAD_URL_EXPIRY_MINUTES=15

# Optional local dependency defaults (managed by Aspire)
SQL_IMAGE=mcr.microsoft.com/mssql/server:2022-latest
REDIS_CONNECTION_STRING=redis:6379

# ----------------------------------------
# Microsoft Entra authentication (recommended)
# ----------------------------------------
# Local default keeps first-run F5 friction-free.
# Set to true after configuring ENTRA_* values to exercise OAuth locally.
ENTRA_AUTH_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_AUTHORITY=
ENTRA_API_CLIENT_ID=
ENTRA_AUDIENCE=
ENTRA_SPA_CLIENT_ID=
ENTRA_SCOPE=